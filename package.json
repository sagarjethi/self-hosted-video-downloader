{
  "name": "self-hosted-video-downloader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Downcut — self-hosted YouTube & Instagram downloader with a built-in online video cutter. Paste a link, trim a section, download video or audio.",
  "license": "MIT",
  "author": "Sagar <sagarblockchaindev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarjethi/self-hosted-video-downloader.git"
  },
  "keywords": [
    "youtube-downloader",
    "instagram-downloader",
    "video-cutter",
    "video-trimmer",
    "yt-dlp",
    "self-hosted",
    "youtube-to-mp3",
    "instagram-reels"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
